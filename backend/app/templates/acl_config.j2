! Generated by Intent-Based Network Controller
! Policy: {{ policy_name }} (ID {{ policy_id }})
{% if vendor == "Juniper" %}
set firewall family inet filter IBN-{{ policy_id }} term INTENT from source-address {{ acl_rules[0].src_prefix }}
set firewall family inet filter IBN-{{ policy_id }} term INTENT from destination-address {{ acl_rules[0].dst_prefix }}
set firewall family inet filter IBN-{{ policy_id }} term INTENT then {{ "accept" if acl_rules[0].action == "permit" else "discard" }}
set interfaces {{ interface_name }} unit 0 family inet filter input IBN-{{ policy_id }}
{% else %}
ip access-list extended IBN_POLICY_{{ policy_id }}
{% for rule in acl_rules %}
 {{ rule.action }} ip {{ rule.src_cidr }} {{ rule.dst_cidr }}
{% endfor %}
 permit ip any any
interface {{ interface_name }}
 description IBN policy {{ policy_name }}
 ip access-group IBN_POLICY_{{ policy_id }} in
{% if vlan_id %}
 switchport access vlan {{ vlan_id }}
{% endif %}
{% endif %}
